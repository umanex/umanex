diff --git a/ios/ExpoHead.podspec b/ios/ExpoHead.podspec
index 4205de5bcc1710da7b57439ac7c5cbe3b2f5f814..4be2dc55cbe31e8580522aa87333c1ff1a827306 100644
--- a/ios/ExpoHead.podspec
